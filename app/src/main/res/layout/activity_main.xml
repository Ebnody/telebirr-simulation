<?xml version="1.0" encoding="utf-8"?>
<ViewFlipper xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/viewFlipper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tele_bg_white">

    <!-- Screen 1: Send Money -->
    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="match_parent"
        android:orientation="vertical" 
        android:padding="20dp">
        
        <TextView 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:text="Transfer Money" 
            android:textSize="22sp" 
            android:textStyle="bold"
            android:textColor="@color/tele_dark_text"/>
        
        <EditText 
            android:id="@+id/etReceiver" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:hint="Receiver Name" 
            android:layout_marginTop="30dp"
            android:backgroundTint="@color/tele_green"/>
        
        <EditText 
            android:id="@+id/etAmount" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:hint="Amount (ETB)" 
            android:inputType="numberDecimal" 
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/tele_green"/>
        
        <Button 
            android:id="@+id/btnSend" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:text="Next" 
            android:layout_marginTop="30dp" 
            android:backgroundTint="@color/tele_green"/>
        
        <TextView 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:text="Simulation / Training Mode" 
            android:gravity="center" 
            android:textColor="#F00" 
            android:layout_marginTop="10dp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Screen 2: Confirmation -->
    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="match_parent"
        android:orientation="vertical" 
        android:padding="20dp"
        android:gravity="center">
        
        <TextView 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:text="Confirm Transaction" 
            android:textSize="20sp" 
            android:textStyle="bold"
            android:textColor="@color/tele_dark_text"
            android:layout_marginBottom="30dp"/>
        
        <TextView 
            android:id="@+id/tvConfirmAmount"
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/tele_dark_text"
            android:layout_marginBottom="20dp"/>
        
        <TextView 
            android:id="@+id/tvConfirmReceiver"
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/tele_text_grey"
            android:layout_marginBottom="30dp"/>
        
        <LinearLayout 
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <Button 
                android:id="@+id/btnCancel" 
                android:layout_width="0dp" 
                android:layout_height="wrap_content"
                android:text="Cancel" 
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:backgroundTint="@color/tele_text_grey"/>
            
            <Button 
                android:id="@+id/btnConfirm" 
                android:layout_width="0dp" 
                android:layout_height="wrap_content"
                android:text="Confirm" 
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:backgroundTint="@color/tele_green"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Screen 3: PIN Entry -->
    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="match_parent"
        android:gravity="center" 
        android:orientation="vertical" 
        android:padding="20dp">
        
        <TextView 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:text="Enter 4-Digit PIN" 
            android:textSize="18sp"
            android:textColor="@color/tele_dark_text"
            android:layout_marginBottom="20dp"/>
        
        <EditText 
            android:id="@+id/etPin" 
            android:layout_width="150dp" 
            android:layout_height="wrap_content"
            android:inputType="numberPassword" 
            android:maxLength="4" 
            android:gravity="center" 
            android:textSize="24sp"
            android:backgroundTint="@color/tele_green"/>
        
        <Button 
            android:id="@+id/btnConfirmPin" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:text="Confirm" 
            android:layout_marginTop="20dp" 
            android:backgroundTint="@color/tele_green"/>
    </LinearLayout>

    <!-- Screen 4: Processing -->
    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="match_parent"
        android:gravity="center" 
        android:orientation="vertical" 
        android:padding="20dp">
        
        <ProgressBar 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/tele_green"/>
        
        <TextView 
            android:id="@+id/tvProcessingText"
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:text="Sending..." 
            android:textSize="18sp"
            android:textColor="@color/tele_dark_text"
            android:layout_marginTop="20dp"/>
    </LinearLayout>

    <!-- Screen 5: Success -->
    <ScrollView 
        android:layout_width="match_parent" 
        android:layout_height="match_parent">
        
        <LinearLayout 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:orientation="vertical" 
            android:padding="16dp">
            
            <TextView 
                android:id="@+id/btnDownload" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:text="📄 Download Receipt" 
                android:textColor="@color/tele_green" 
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_gravity="end"/>

            <ImageView 
                android:layout_width="80dp" 
                android:layout_height="80dp" 
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_save" 
                android:tint="@color/tele_green" 
                android:layout_marginTop="20dp"/>
            
            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:layout_gravity="center" 
                android:text="Successful" 
                android:textColor="@color/tele_green"
                android:textSize="20sp" 
                android:textStyle="bold"/>

            <TextView 
                android:id="@+id/tvDispAmount" 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:layout_gravity="center" 
                android:textSize="32sp" 
                android:textStyle="bold" 
                android:layout_marginTop="20dp"
                android:textColor="@color/tele_dark_text"/>

            <TableLayout 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                android:layout_marginTop="30dp" 
                android:stretchColumns="1">
                
                <TableRow android:padding="8dp">
                    <TextView android:text="Transaction Time" android:textColor="@color/tele_text_grey"/>
                    <TextView android:id="@+id/tvDispTime" android:gravity="end" android:textStyle="bold" android:textColor="@color/tele_dark_text"/>
                </TableRow>
                
                <TableRow android:padding="8dp">
                    <TextView android:text="Transaction Type" android:textColor="@color/tele_text_grey"/>
                    <TextView android:text="Transfer Money" android:gravity="end" android:textStyle="bold" android:textColor="@color/tele_dark_text"/>
                </TableRow>
                
                <TableRow android:padding="8dp">
                    <TextView android:text="Transaction To" android:textColor="@color/tele_text_grey"/>
                    <TextView android:id="@+id/tvDispRec" android:gravity="end" android:textStyle="bold" android:textColor="@color/tele_dark_text"/>
                </TableRow>
                
                <TableRow android:padding="8dp">
                    <TextView android:text="Transaction Number" android:textColor="@color/tele_text_grey"/>
                    <TextView android:id="@+id/tvDispID" android:gravity="end" android:textStyle="bold" android:textColor="@color/tele_dark_text"/>
                </TableRow>
            </TableLayout>

            <Button 
                android:id="@+id/btnDone" 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Finished" 
                android:layout_marginTop="40dp" 
                android:backgroundTint="@color/tele_green"/>
        </LinearLayout>
    </ScrollView>
</ViewFlipper>
